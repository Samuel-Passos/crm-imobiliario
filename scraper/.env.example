# Configurações do Supabase
SUPABASE_URL=sua_url_aqui
SUPABASE_KEY=sua_key_aqui

# Configurações do LLM (Groq)
GROQ_API_KEY=sua_api_key_aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Configuração do Browser Use
CHROME_PROFILE_PATH=/home/samuel/.config/google-chrome

# Segundo motor de geocodificação (Google Maps Geocoding API)
# Obtenha em: console.cloud.google.com → APIs & Services → Geocoding API
GOOGLE_MAPS_API_KEY=sua_chave_aqui
